{
  "plugin": "org.smartide.plugin.python",
  "run": "python main.py",
  "intelligence": {
    ".json": {
      "enabled": true,
      "run": "vscode-json-language-server --stdio"
    },
    ".cpp": {
      "enabled": false,
      "run": "clangd"
    },
    ".kt": {
      "enabled": true,
      "run": "kotlin-language-server"
    },
    ".xml": {
      "enabled": false,
      "run": "lemminx"
    },
    ".h": {
      "enabled": false,
      "run": "clangd"
    },
    ".html": {
      "enabled": false,
      "run": "vscode-html-language-server --stdio"
    },
    ".yml": {
      "enabled": false,
      "run": "yaml-language-server --stdio"
    },
    ".kts": {
      "enabled": false,
      "run": "kotlin-language-server"
    },
    ".md": {
      "enabled": true,
      "run": "marksman server"
    }
  }
}